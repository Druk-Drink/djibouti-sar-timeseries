# NASA Earthdata Credentials
# Register at: https://urs.earthdata.nasa.gov/users/new
# Copy this file to .env and fill in your credentials

EARTHDATA_USERNAME=your_username_here
EARTHDATA_PASSWORD=your_password_here

# SNAP GPT Path (optional - auto-detected if not set)
# macOS: /Applications/snap/bin/gpt or /Applications/esa-snap/bin/gpt
# Linux: /usr/local/snap/bin/gpt or ~/snap/bin/gpt
# Windows: C:/Program Files/snap/bin/gpt.exe
# SNAP_GPT_PATH=/Applications/esa-snap/bin/gpt
